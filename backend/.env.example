# Port the API server listens on
PORT=8787

# Comma-separated list of origins allowed to call this API (your deployed frontend URL + localhost for dev)
CORS_ORIGIN=http://localhost:5173

# How long a fetched USGS feed is cached before re-fetching, in ms.
# USGS feeds themselves only refresh ~once/minute, so this just avoids
# hammering a shared public resource on every poll.
CACHE_TTL_MS=30000

# Per-request timeout before giving up on USGS, in ms
USGS_TIMEOUT_MS=8000
